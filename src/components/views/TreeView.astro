---
import FamilyTree from "../FamilyTree.tsx";
import ViewModeToggle from "../ViewModeToggle.astro";
import { getPeople, type PeopleView } from "../../lib/people";
import { useTranslations, localize, type Locale } from "../../i18n/ui";

interface Props {
  lang: Locale;
  view?: PeopleView;
}
const { lang, view = "core" } = Astro.props;
const t = useTranslations(lang);

const people = await getPeople(view);
const dataUrl = localize(view === "extended" ? "/extended/tree-data.json" : "/tree-data.json", lang);
const peoplePath = localize(view === "extended" ? "/extended/people" : "/people", lang);

const labels = {
  hint: t("tree.hint"),
  zoomIn: t("tree.zoomIn"),
  zoomOut: t("tree.zoomOut"),
  reset: t("tree.reset"),
  fullscreen: t("tree.fullscreen"),
  exitFullscreen: t("tree.exitFullscreen"),
  expandAll: t("tree.expandAll"),
  collapseAll: t("tree.collapseAll"),
  living: t("tree.living"),
  deceased: t("tree.deceased"),
  born: t("person.born"),
  died: t("person.died"),
  birthplace: t("person.birthplace"),
  female: t("tree.female"),
  male: t("tree.male"),
  showMore: t("tree.showMore"),
  search: t("tree.search"),
  searchPlaceholder: t("tree.searchPlaceholder"),
  searchEmpty: t("tree.searchEmpty"),
  center: t("tree.center"),
  loading: t("tree.loading"),
  branchMode: t("tree.branchMode"),
  showAll: t("tree.showAll"),
};
---

<section
  class="tree-topper mx-auto flex max-w-[1600px] flex-col gap-4 px-5 pt-10 pb-4 sm:flex-row sm:flex-wrap sm:items-end sm:justify-between"
>
  <div>
    <p class="eyebrow">{t("home.eyebrow", { n: people.length })}</p>
    <h1 class="mt-3 text-4xl font-semibold text-ink">
      {t("tree.title")}
    </h1>
    <p class="mt-2 max-w-2xl text-muted">{t("tree.subtitle")}</p>
  </div>
  <a
    href={localize("/poster.svg", lang)}
    download
    class="button-secondary w-fit text-sm"
  >
    ↓ {t("tree.poster")}
  </a>
  <ViewModeToggle lang={lang} current={view} section="tree" />
</section>

<section class="mx-auto max-w-[1600px] px-5 pb-12">
  <FamilyTree
    client:load
    dataUrl={dataUrl}
    labels={labels}
    basePath={peoplePath}
  />
</section>
