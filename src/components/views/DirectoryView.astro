---
import Avatar from "../Avatar.astro";
import {
  getPeople,
  getTranslations,
  taglineFor,
  lifespan,
  initials,
} from "../../lib/people";
import { useTranslations, localize, type Locale } from "../../i18n/ui";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const people = await getPeople();
const translations = await getTranslations();
const peoplePath = localize("/people", lang);
const locale = lang === "bs" ? "bs-BA" : "en-US";
const groups = new Map<string, typeof people>();
for (const person of people) {
  const letter = person.data.name.trim()[0]?.toLocaleUpperCase(locale) ?? "#";
  if (!groups.has(letter)) groups.set(letter, []);
  groups.get(letter)!.push(person);
}
const groupedPeople = [...groups.entries()].sort(([a], [b]) =>
  a.localeCompare(b, locale),
);
---

<section class="mx-auto max-w-6xl px-5 py-10 sm:py-12">
  <div class="directory-hero">
    <div>
      <p class="eyebrow">{t("dir.count", { n: people.length })}</p>
      <h1 class="mt-3 text-4xl font-semibold text-ink">
        {t("dir.title")}
      </h1>
      <p class="mt-2 max-w-2xl text-muted">{t("dir.subtitle")}</p>
    </div>

    <form role="search" class="directory-search">
      <label class="block">
        <span class="sr-only">{t("dir.search")}</span>
        <input
          id="search"
          name="q"
          type="search"
          placeholder={t("dir.search")}
          autocomplete="off"
          class="search-input"
        />
      </label>
      <p
        id="result-count"
        data-template={t("dir.results", { n: "{n}" })}
        class="mt-2 text-sm text-muted"
        aria-live="polite"
      >
        {t("dir.results", { n: people.length })}
      </p>
    </form>
  </div>

  <nav class="letter-nav" aria-label={t("dir.jump")}>
    {
      groupedPeople.map(([letter]) => (
        <a
          href={`#letter-${letter}`}
          class="letter-link"
        >
          {letter}
        </a>
      ))
    }
  </nav>

  <div id="people-grid" class="mt-8 space-y-10">
    {
      groupedPeople.map(([letter, group]) => (
        <section class="letter-section letter-section-panel scroll-mt-24" id={`letter-${letter}`}>
          <div class="mb-3 flex items-center gap-3">
            <h2 class="text-2xl font-semibold text-ink">
              {letter}
            </h2>
            <span class="h-px flex-1 bg-line" />
            <span class="text-sm text-muted">{group.length}</span>
          </div>
          <ul class="grid grid-cols-[minmax(0,1fr)] gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {group.map((p) => (
              <li
                class="person-item min-w-0"
                data-name={`${p.data.name} ${p.data.maidenName ?? ""} ${p.data.nickname ?? ""} ${taglineFor(p, translations, lang) ?? ""} ${lifespan(p, lang)}`.toLowerCase()}
              >
                <a
                  href={`${peoplePath}/${p.id}`}
                  class="person-card person-card-quiet flex h-full w-full min-w-0 items-center gap-3 p-3"
                  data-sex={p.data.sex}
                >
                  <Avatar
                    name={p.data.name}
                    photo={p.data.photo}
                    initials={initials(p.data.name)}
                    sex={p.data.sex}
                  />
                  <span class="min-w-0 flex-1">
                    <span class="block truncate font-semibold text-ink">
                      {p.data.name}
                    </span>
                    <span class="mt-0.5 block truncate text-sm text-muted">
                      {[lifespan(p, lang), taglineFor(p, translations, lang)]
                        .filter(Boolean)
                        .join(" · ")}
                    </span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>

  <p id="no-results" class="surface-panel mt-8 hidden p-4 text-muted">{t("dir.empty")}</p>
</section>

<script>
  const input = document.getElementById("search") as HTMLInputElement;
  const items = Array.from(
    document.querySelectorAll<HTMLElement>(".person-item"),
  );
  const sections = Array.from(
    document.querySelectorAll<HTMLElement>(".letter-section"),
  );
  const empty = document.getElementById("no-results")!;
  const count = document.getElementById("result-count")!;
  const template = count.dataset.template ?? "{n}";

  const filter = () => {
    const q = input.value.trim().toLowerCase();
    let shown = 0;
    for (const item of items) {
      const match = (item.dataset.name ?? "").includes(q);
      item.hidden = !match;
      if (match) shown++;
    }
    for (const section of sections) {
      const visible = section.querySelectorAll(".person-item:not([hidden])").length;
      section.hidden = visible === 0;
    }
    empty.classList.toggle("hidden", shown !== 0);
    count.textContent = template.replace("{n}", String(shown));

    const url = new URL(location.href);
    if (q) url.searchParams.set("q", q);
    else url.searchParams.delete("q");
    history.replaceState(null, "", url);
  };

  const initial = new URLSearchParams(location.search).get("q");
  if (initial && input) input.value = initial;
  input?.addEventListener("input", filter);
  filter();
</script>
