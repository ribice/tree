---
import Avatar from "../Avatar.astro";
import {
  getPeople,
  getTranslations,
  taglineFor,
  lifespan,
  initials,
  birthYear,
  generation,
  isLiving,
} from "../../lib/people";
import { useTranslations, localize, type Locale } from "../../i18n/ui";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const people = await getPeople();
const translations = await getTranslations();

const byYearAsc = [...people].sort(
  (a, b) => (birthYear(a) ?? Infinity) - (birthYear(b) ?? Infinity),
);
const oldest = byYearAsc.filter((p) => birthYear(p) !== null).slice(0, 4);
const youngest = [...people]
  .sort(
    (a, b) =>
      generation(b, people) - generation(a, people) ||
      (birthYear(b) ?? 0) - (birthYear(a) ?? 0),
  )
  .slice(0, 4);

const peoplePath = localize("/people", lang);
const treePath = localize("/tree", lang);

const years = people
  .flatMap((p) => [p.data.born, p.data.died])
  .map((v) => v?.match(/\d{4}/)?.[0])
  .filter((v): v is string => Boolean(v))
  .map(Number);
const minYear = Math.min(...years);
const maxYear = Math.max(...years);
const generationCount = Math.max(...people.map((p) => generation(p, people)));
const livingCount = people.filter((p) => isLiving(p)).length;
const recordedYears = maxYear - minYear + 1;

const timeline = [...oldest.slice(0, 3), ...youngest.slice(0, 3)].filter(
  (person, index, arr) => arr.findIndex((p) => p.id === person.id) === index,
);

const features = [
  { title: t("home.f1.title"), body: t("home.f1.body") },
  { title: t("home.f2.title"), body: t("home.f2.body") },
  { title: t("home.f3.title"), body: t("home.f3.body") },
];

const rows = [
  { title: t("home.oldest"), people: oldest },
  { title: t("home.recent"), people: youngest },
];

const stats = [
  { value: String(people.length), label: t("home.statPeople") },
  { value: String(generationCount), label: t("home.statGenerations") },
  { value: String(recordedYears), label: t("home.statYears") },
  { value: String(livingCount), label: t("stats.living").toLowerCase() },
];
---

<section class="heritage-band">
  <div class="relative mx-auto max-w-6xl px-5 pt-16 pb-12 sm:pt-20">
    <p class="eyebrow">{t("home.eyebrow", { n: people.length })}</p>
    <h1
      class="mt-4 max-w-4xl text-4xl font-semibold tracking-tight text-balance text-ink sm:text-6xl"
    >
      {t("home.title")}
    </h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-pretty text-muted sm:text-xl">
      {t("home.intro")}
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href={treePath} class="button-primary">
        {t("home.ctaTree")} →
      </a>
      <a href={peoplePath} class="button-secondary">
        {t("home.ctaDirectory")}
      </a>
    </div>

    <dl class="mt-10 grid gap-3 sm:grid-cols-4">
      {
        stats.map((s) => (
          <div class="soft-panel px-4 py-3">
            <dt class="text-sm text-muted">{s.label}</dt>
            <dd class="mt-1 text-2xl font-semibold tracking-tight text-ink">
              {s.value}
            </dd>
          </div>
        ))
      }
    </dl>

    <div class="surface-panel mt-10 p-4 sm:p-5" aria-label={t("home.timeline")}>
      <div class="flex items-center justify-between gap-4">
        <h2 class="text-sm font-semibold tracking-wide text-muted uppercase">
          {t("home.timeline")}
        </h2>
        <span class="text-sm font-medium text-accent">{minYear}–{maxYear}</span>
      </div>
      <ol class="relative mt-6 grid gap-4 sm:grid-cols-6">
        <span
          class="absolute top-[1.65rem] right-4 left-4 hidden h-px bg-branch sm:block"
        ></span>
        {
          timeline.map((p) => (
            <li class="relative">
              <a
                href={`${peoplePath}/${p.id}`}
                class="group block rounded-lg bg-surface/85 p-2 text-center transition hover:bg-accent-soft"
              >
                <span class="mx-auto block h-3 w-3 rounded-full bg-gold ring-4 ring-surface transition group-hover:bg-accent" />
                <span class="mt-3 block truncate text-sm font-semibold text-ink group-hover:text-accent">
                  {p.data.name}
                </span>
                <span class="mt-0.5 block truncate text-xs text-muted">
                  {lifespan(p, lang)}
                </span>
              </a>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<section class="mx-auto grid max-w-6xl gap-8 px-5 py-12 lg:grid-cols-[0.8fr_1.2fr]">
  <div>
    <p class="eyebrow">{t("home.archive")}</p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight text-balance text-ink">
      {t("home.archiveTitle")}
    </h2>
    <p class="mt-3 leading-7 text-muted">{t("home.archiveBody")}</p>
  </div>
  <div class="grid gap-4 sm:grid-cols-3">
    {
      features.map((f) => (
        <div class="soft-panel p-4">
          <h3 class="font-semibold text-ink">{f.title}</h3>
          <p class="mt-2 text-sm leading-6 text-muted">{f.body}</p>
        </div>
      ))
    }
  </div>
</section>

<section class="mx-auto grid max-w-6xl gap-8 px-5 pb-12 sm:grid-cols-2">
  {
    rows.map((row) => (
      <div>
        <h2 class="text-sm font-semibold tracking-wide text-muted uppercase">
          {row.title}
        </h2>
        <ul class="mt-3 space-y-2">
          {row.people.map((p) => (
            <li>
              <a
                href={`${peoplePath}/${p.id}`}
                class="person-card flex items-center gap-3 p-2.5"
              >
                <Avatar
                  name={p.data.name}
                  photo={p.data.photo}
                  initials={initials(p.data.name)}
                />
                <span class="min-w-0">
                  <span class="block truncate font-medium text-ink">
                    {p.data.name}
                  </span>
                  <span class="block truncate text-sm text-muted">
                    {[lifespan(p, lang), taglineFor(p, translations, lang)]
                      .filter(Boolean)
                      .join(" · ")}
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</section>
