---
import Avatar from "../Avatar.astro";
import {
  getPeople,
  getTranslations,
  taglineFor,
  lifespan,
  initials,
  birthYear,
  generation,
} from "../../lib/people";
import { useTranslations, localize, type Locale } from "../../i18n/ui";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const people = await getPeople();
const translations = await getTranslations();

const byYearAsc = [...people].sort(
  (a, b) => (birthYear(a) ?? Infinity) - (birthYear(b) ?? Infinity),
);
const oldest = byYearAsc.filter((p) => birthYear(p) !== null).slice(0, 4);
const youngest = [...people]
  .sort(
    (a, b) =>
      generation(b, people) - generation(a, people) ||
      (birthYear(b) ?? 0) - (birthYear(a) ?? 0),
  )
  .slice(0, 4);

const peoplePath = localize("/people", lang);

const features = [
  { title: t("home.f1.title"), body: t("home.f1.body") },
  { title: t("home.f2.title"), body: t("home.f2.body") },
  { title: t("home.f3.title"), body: t("home.f3.body") },
];

const rows = [
  { title: t("home.oldest"), people: oldest },
  { title: t("home.recent"), people: youngest },
];
---

<section class="mx-auto max-w-6xl px-5 pt-16 pb-10">
  <p class="text-sm font-medium tracking-wide text-accent uppercase">
    {t("home.eyebrow", { n: people.length })}
  </p>
  <h1
    class="mt-3 max-w-3xl text-4xl font-semibold tracking-tight text-balance text-ink sm:text-5xl"
  >
    {t("home.title")}
  </h1>
  <p class="mt-4 max-w-2xl text-lg text-pretty text-muted">
    {t("home.intro")}
  </p>
  <div class="mt-7 flex flex-wrap gap-3">
    <a
      href={localize("/tree", lang)}
      class="rounded-xl bg-accent px-5 py-2.5 font-medium text-surface shadow-sm transition hover:opacity-90"
    >
      {t("home.ctaTree")} →
    </a>
    <a
      href={peoplePath}
      class="rounded-xl border border-line bg-surface px-5 py-2.5 font-medium text-ink shadow-sm transition hover:border-accent hover:text-accent"
    >
      {t("home.ctaDirectory")}
    </a>
  </div>
</section>

<section class="mx-auto grid max-w-6xl gap-8 px-5 pb-4 sm:grid-cols-2">
  {
    rows.map((row) => (
      <div>
        <h2 class="text-sm font-semibold tracking-wide text-muted uppercase">
          {row.title}
        </h2>
        <ul class="mt-3 space-y-2">
          {row.people.map((p) => (
            <li>
              <a
                href={`${peoplePath}/${p.id}`}
                class="flex items-center gap-3 rounded-xl border border-line bg-surface p-2.5 shadow-sm transition hover:border-accent hover:shadow-md"
              >
                <Avatar
                  name={p.data.name}
                  photo={p.data.photo}
                  initials={initials(p.data.name)}
                />
                <span class="min-w-0">
                  <span class="block truncate font-medium text-ink">
                    {p.data.name}
                  </span>
                  <span class="block truncate text-sm text-muted">
                    {[lifespan(p, lang), taglineFor(p, translations, lang)]
                      .filter(Boolean)
                      .join(" · ")}
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</section>

<section class="border-t border-line bg-surface">
  <div class="mx-auto grid max-w-6xl gap-8 px-5 py-12 sm:grid-cols-3">
    {
      features.map((f) => (
        <div>
          <h2 class="font-semibold text-ink">{f.title}</h2>
          <p class="mt-1.5 text-sm text-muted">{f.body}</p>
        </div>
      ))
    }
  </div>
</section>
