---
import Avatar from "../Avatar.astro";
import {
  getPeople,
  getTranslations,
  lifespan,
  initials,
  birthYear,
  generation,
  isLiving,
} from "../../lib/people";
import { displayTaglineFor } from "../../lib/display";
import { useTranslations, localize, type Locale } from "../../i18n/ui";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const people = await getPeople();
const translations = await getTranslations();
const peopleById = new Map(people.map((p) => [p.id, p]));
const lineageIds = [
  "enes-predak",
  "omer",
  "avdikadija",
  "akif",
  "avdo-kifin",
  "rasim",
  "halim",
  "esad",
  "emir",
  "jakub-emirov",
] as const;
const lineage = lineageIds
  .map((id) => peopleById.get(id))
  .filter((p): p is (typeof people)[number] => Boolean(p));

const byYearAsc = [...people].sort(
  (a, b) => (birthYear(a) ?? Infinity) - (birthYear(b) ?? Infinity),
);
const oldest = byYearAsc.filter((p) => birthYear(p) !== null).slice(0, 4);
const youngest = [...people]
  .sort(
    (a, b) =>
      generation(b, people) - generation(a, people) ||
      (birthYear(b) ?? 0) - (birthYear(a) ?? 0),
  )
  .slice(0, 4);

const peoplePath = localize("/people", lang);
const treePath = localize("/tree", lang);
const addPath = localize("/add", lang);
const githubUrl = "https://github.com/ribice/tree";

const years = people
  .flatMap((p) => [p.data.born, p.data.died])
  .map((v) => v?.match(/\d{4}/)?.[0])
  .filter((v): v is string => Boolean(v))
  .map(Number);
const minYear = Math.min(...years);
const maxYear = Math.max(...years);
const generationCount = Math.max(...people.map((p) => generation(p, people)));
const livingCount = people.filter((p) => isLiving(p)).length;
const recordedYears = maxYear - minYear + 1;

const heroPeople = [...lineage.slice(0, 3), ...lineage.slice(-2)].filter(
  (person, index, arr) => arr.findIndex((p) => p.id === person.id) === index,
);

const rows = [
  { title: t("home.oldest"), people: oldest },
  { title: t("home.recent"), people: youngest },
];

const stats = [
  { value: String(people.length), label: t("home.statPeople") },
  { value: String(generationCount), label: t("home.statGenerations") },
  { value: String(recordedYears), label: t("home.statYears") },
  { value: String(livingCount), label: t("stats.living").toLowerCase() },
];
---

<section class="heritage-band">
  <div class="relative mx-auto grid max-w-6xl grid-cols-[minmax(0,1fr)] gap-10 px-5 pt-16 pb-12 sm:pt-20 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:items-center">
    <div class="min-w-0">
      <p class="eyebrow">{t("home.eyebrow", { n: people.length })}</p>
      <h1
        class="mt-4 max-w-4xl text-4xl font-semibold text-balance text-ink sm:text-6xl"
      >
        {t("home.title")}
      </h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-pretty text-muted sm:text-xl">
        {t("home.intro")}
      </p>
      <div class="home-actions mt-8">
        <a href={treePath} class="button-primary">
          {t("home.ctaTree")} →
        </a>
        <a href={peoplePath} class="button-secondary">
          {t("home.ctaDirectory")}
        </a>
      </div>

      <dl class="mt-10 grid gap-3 sm:grid-cols-4">
        {
          stats.map((s) => (
            <div class="stat-tile">
              <dt>{s.label}</dt>
              <dd>{s.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="family-ledger" aria-label={t("home.timeline")}>
      <div class="family-ledger-head">
        <p>{t("home.timeline")}</p>
        <h2>{t("site.short")}</h2>
        <span>{minYear}–{maxYear}</span>
      </div>

      <div class="family-ledger-list">
        {
          heroPeople.map((p) => (
            <a
              href={`${peoplePath}/${p.id}`}
              class="family-ledger-person"
              data-sex={p.data.sex}
            >
              <Avatar
                name={p.data.name}
                photo={p.data.photo}
                initials={initials(p.data.name)}
                sex={p.data.sex}
                size="xs"
              />
              <span>
                <strong>{p.data.name}</strong>
                <small>{lifespan(p, lang)}</small>
              </span>
            </a>
          ))
        }
      </div>

      <dl class="family-ledger-stats">
        {
          stats.slice(0, 3).map((s) => (
            <div>
              <dt>{s.label}</dt>
              <dd>{s.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="lineage-panel lg:col-span-2" aria-label={t("home.timeline")}>
      <div class="lineage-intro">
        <div>
          <p class="eyebrow">{t("home.lineageKicker")}</p>
          <h2>{t("home.timeline")}</h2>
        </div>
        <p>{t("home.lineageBody")}</p>
        <span>{lineage.length} {t("home.statGenerations")}</span>
      </div>
      <ol class="lineage-track" style={`--lineage-count: ${lineage.length}`}>
        {
          lineage.map((p, index) => (
            <li class="lineage-item">
              <a
                href={`${peoplePath}/${p.id}`}
                class="lineage-card"
                data-sex={p.data.sex}
              >
                <span class="lineage-card-head">
                  <span class="lineage-step">
                    {t("home.lineageStep", { n: index + 1 })}
                  </span>
                  <Avatar
                    name={p.data.name}
                    photo={p.data.photo}
                    initials={initials(p.data.name)}
                    sex={p.data.sex}
                    size="xs"
                  />
                </span>
                <span class="lineage-card-name">{p.data.name}</span>
                <span class="lineage-card-meta">
                  {[lifespan(p, lang), displayTaglineFor(p, people, translations, lang)]
                    .filter(Boolean)
                    .join(" · ")}
                </span>
              </a>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<section class="mx-auto max-w-6xl px-5 py-12">
  <div class="home-about">
    <div class="home-about-title">
      <p class="eyebrow">{t("home.aboutKicker")}</p>
      <h2>{t("home.aboutTitle")}</h2>
    </div>
    <div class="home-about-copy">
      <p>{t("home.aboutP1")}</p>
      <p>{t("home.aboutP2")}</p>
      <p>{t("home.aboutP3")}</p>
      <p>{t("home.aboutP4")}</p>
      <div class="home-actions mt-6">
        <a href={addPath} class="button-primary">{t("nav.add")}</a>
        <a href={githubUrl} class="button-secondary">{t("footer.github")}</a>
      </div>
    </div>
  </div>
</section>

<section
  class="mx-auto grid max-w-6xl grid-cols-[minmax(0,1fr)] gap-6 px-5 pb-12 sm:grid-cols-2"
>
  {
    rows.map((row) => (
      <section class="surface-panel min-w-0 p-4 sm:p-5">
        <div class="flex min-w-0 items-center justify-between gap-3">
          <h2 class="min-w-0 text-sm font-semibold tracking-wide text-muted uppercase">
            {row.title}
          </h2>
          <span class="h-px min-w-8 flex-1 bg-line" />
        </div>
        <ul class="mt-4 grid grid-cols-[minmax(0,1fr)] gap-2">
          {row.people.map((p) => (
            <li class="min-w-0">
              <a
                href={`${peoplePath}/${p.id}`}
                class="person-card person-card-quiet flex w-full min-w-0 items-center gap-3 p-2.5"
                data-sex={p.data.sex}
              >
                <Avatar
                  name={p.data.name}
                  photo={p.data.photo}
                  initials={initials(p.data.name)}
                  sex={p.data.sex}
                />
                <span class="min-w-0 flex-1">
                  <span class="block truncate font-medium text-ink">
                    {p.data.name}
                  </span>
                  <span class="block truncate text-sm text-muted">
                      {[lifespan(p, lang), displayTaglineFor(p, people, translations, lang)]
                        .filter(Boolean)
                        .join(" · ")}
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</section>
