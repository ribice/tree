---
import ViewModeToggle from "../ViewModeToggle.astro";
import { getPeople, birthYear, generation, isLiving, type PeopleView } from "../../lib/people";
import { useTranslations, type Locale } from "../../i18n/ui";
import { collectDataQuality } from "../../lib/data-quality";
import StatTile from "../ui/StatTile.astro";

interface Props {
  lang: Locale;
  view?: PeopleView;
}
const { lang, view = "core" } = Astro.props;
const t = useTranslations(lang);

const people = await getPeople(view);
const qualityGroups = collectDataQuality(people);
const dataIssueCount = qualityGroups.reduce((sum, group) => sum + group.issues.length, 0);

const years: number[] = [];
for (const p of people) {
  for (const v of [p.data.born, p.data.died]) {
    const m = v?.match(/\d{4}/);
    if (m) years.push(Number(m[0]));
  }
}
const minYear = years.length ? Math.min(...years) : null;
const maxYear = years.length ? Math.max(...years) : null;

const generations = Math.max(...people.map((p) => generation(p, people)));
const livingCount = people.filter((p) => isLiving(p)).length;

const surname = (name: string) =>
  name.split("—")[0].trim().split(/\s+/).pop() ?? "";
const tally = (vals: (string | undefined)[]) => {
  const m = new Map<string, number>();
  for (const v of vals) if (v) m.set(v, (m.get(v) ?? 0) + 1);
  return [...m.entries()].sort((a, b) => b[1] - a[1]);
};

const surnames = tally(people.map((p) => surname(p.data.name)));
const places = tally(people.map((p) => p.data.birthplace));

const cards = [
  { label: t("stats.people"), value: String(people.length) },
  { label: t("stats.generations"), value: String(generations) },
  { label: t("stats.living"), value: String(livingCount) },
  { label: t("stats.dataIssues"), value: String(dataIssueCount) },
  {
    label: t("stats.span"),
    value: minYear && maxYear ? `${minYear}–${maxYear}` : "—",
  },
];

const maxSurnameCount = surnames[0]?.[1] ?? 1;
const maxPlaceCount = places[0]?.[1] ?? 1;
const pct = (count: number) => Math.round((count / Math.max(people.length, 1)) * 100);
const completenessCards = [
  {
    label: t("stats.withBirth"),
    count: people.filter((p) => p.data.born).length,
  },
  {
    label: t("stats.withBirthplace"),
    count: people.filter((p) => p.data.birthplace).length,
  },
  {
    label: t("stats.withParents"),
    count: people.filter((p) => p.data.parents.length > 0).length,
  },
  {
    label: t("stats.withBio"),
    count: people.filter((p) => p.body?.trim()).length,
  },
  {
    label: t("stats.withPhoto"),
    count: people.filter((p) => p.data.photo).length,
  },
].map((item) => ({ ...item, percent: pct(item.count) }));

const generationMap = new Map<number, number>();
for (const person of people) {
  const gen = generation(person, people);
  generationMap.set(gen, (generationMap.get(gen) ?? 0) + 1);
}
const generationRows = [...generationMap.entries()]
  .sort((a, b) => a[0] - b[0])
  .map(([gen, count]) => ({
    label: t("person.generation", { n: gen }),
    count,
    percent: pct(count),
  }));

// Decade labels read "1970s" in English but "1970-e" in Bosnian.
const decadeSuffix = lang === "en" ? "s" : "-e";
const decadeMap = new Map<string, number>();
for (const person of people) {
  const year = birthYear(person);
  if (!year) continue;
  const decade = Math.floor(year / 10) * 10;
  const key = `${decade}${decadeSuffix}`;
  decadeMap.set(key, (decadeMap.get(key) ?? 0) + 1);
}
const maxDecadeCount = Math.max(...decadeMap.values(), 1);
const decadeRows = [...decadeMap.entries()]
  .sort((a, b) => Number(a[0].slice(0, 4)) - Number(b[0].slice(0, 4)))
  .map(([label, count]) => ({
    label,
    count,
    percent: Math.round((count / maxDecadeCount) * 100),
  }));

// Approximate coordinates for known birthplaces (others simply aren't plotted).
const COORDS: Record<string, [number, number]> = {
  Jezero: [44.2667, 17.2167],
  Jajce: [44.3419, 17.2706],
  Zenica: [44.2017, 17.9072],
  Sarajevo: [43.8563, 18.4131],
  "Gostivar, Makedonija": [41.7967, 20.9089],
};
const mapPoints = places
  .filter(([place]) => COORDS[place])
  .map(([place, count]) => ({
    place,
    count,
    lat: COORDS[place][0],
    lng: COORDS[place][1],
  }));
const bounds = { minLat: 41.2, maxLat: 44.7, minLng: 16.6, maxLng: 21.3 };
const project = (lat: number, lng: number) => ({
  x: ((lng - bounds.minLng) / (bounds.maxLng - bounds.minLng)) * 680 + 30,
  y: ((bounds.maxLat - lat) / (bounds.maxLat - bounds.minLat)) * 300 + 28,
});
const projectedPoints = mapPoints.map((point) => ({
  ...point,
  ...project(point.lat, point.lng),
}));
---

<section class="mx-auto max-w-6xl px-5 py-10 sm:py-12">
  <div class="stats-hero">
    <div>
      <p class="eyebrow">{t("stats.subtitle")}</p>
      <h1 class="mt-3 text-4xl font-semibold text-ink">
        {t("stats.title")}
      </h1>
    </div>
    <ViewModeToggle lang={lang} current={view} section="stats" />
  </div>

  <dl class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-5">
    {
      cards.map((c) => (
        <StatTile label={c.label} value={c.value} />
      ))
    }
  </dl>

  <div class="stats-insight-grid mt-10">
    <section class="stats-insight-card">
      <h2>{t("stats.completeness")}</h2>
      <ul>
        {
          completenessCards.map((item) => (
            <li>
              <div>
                <span>{item.label}</span>
                <strong>{item.percent}%</strong>
              </div>
              <meter min="0" max="100" value={item.percent}>{item.percent}%</meter>
              <small>{item.count}/{people.length}</small>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="stats-insight-card">
      <h2>{t("stats.generationsChart")}</h2>
      <ul>
        {
          generationRows.map((item) => (
            <li>
              <div>
                <span>{item.label}</span>
                <strong>{item.count}</strong>
              </div>
              <meter min="0" max="100" value={item.percent}>{item.percent}%</meter>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="stats-insight-card">
      <h2>{t("stats.decades")}</h2>
      <ul>
        {
          decadeRows.map((item) => (
            <li>
              <div>
                <span>{item.label}</span>
                <strong>{item.count}</strong>
              </div>
              <meter min="0" max="100" value={item.percent}>{item.percent}%</meter>
            </li>
          ))
        }
      </ul>
    </section>
  </div>

  <div class="mt-10 grid gap-8 sm:grid-cols-2">
    <div class="chart-panel p-5">
      <h2 class="text-sm font-semibold tracking-wide text-muted uppercase">
        {t("stats.surnames")}
      </h2>
      <ul class="mt-4 space-y-3">
        {
          surnames.slice(0, 10).map(([name, n]) => (
            <li>
              <div class="mb-1 flex items-center justify-between gap-3 text-sm">
                <span class="font-medium text-ink">{name}</span>
                <span class="text-muted">{n}</span>
              </div>
              <div class="h-2 overflow-hidden rounded-full bg-accent-soft">
                <span
                  class="block h-full rounded-full bg-accent"
                  style={`width: ${(n / maxSurnameCount) * 100}%`}
                />
              </div>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="chart-panel p-5">
      <h2 class="text-sm font-semibold tracking-wide text-muted uppercase">
        {t("stats.places")}
      </h2>
      <ul class="mt-4 space-y-3">
        {
          places.slice(0, 10).map(([name, n]) => (
            <li>
              <div class="mb-1 flex items-center justify-between gap-3 text-sm">
                <span class="font-medium text-ink">{name}</span>
                <span class="text-muted">{n}</span>
              </div>
              <div class="h-2 overflow-hidden rounded-full bg-accent-soft">
                <span
                  class="block h-full rounded-full bg-gold"
                  style={`width: ${(n / maxPlaceCount) * 100}%`}
                />
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  {
    mapPoints.length > 0 && (
      <div class="chart-panel mt-10 overflow-hidden p-5">
        <h2
          id="birthplaces-title"
          class="text-sm font-semibold tracking-wide text-muted uppercase"
        >
          {t("stats.map")}
        </h2>
        <svg
          class="mt-4 h-auto w-full"
          viewBox="0 0 740 370"
          role="img"
          aria-labelledby="birthplaces-title"
        >
          <rect width="740" height="370" rx="8" fill="var(--color-paper)" />
          <path
            d="M96 86 C170 30 305 34 375 92 C470 170 570 128 650 202 C590 286 462 318 340 292 C222 266 120 214 96 86Z"
            fill="var(--color-accent-soft)"
            stroke="var(--color-line)"
            stroke-width="2"
          />
          <path
            d="M112 222 C190 185 255 210 318 176 C388 137 458 159 522 132"
            fill="none"
            stroke="var(--color-branch)"
            stroke-width="2"
            stroke-dasharray="7 8"
          />
          {
            projectedPoints.map((point) => (
              <g>
                <circle
                  cx={point.x}
                  cy={point.y}
                  r={7 + point.count * 1.6}
                  fill="var(--color-accent)"
                  fill-opacity="0.22"
                  stroke="var(--color-accent)"
                  stroke-width="2"
                />
                <circle cx={point.x} cy={point.y} r="3" fill="var(--color-accent)" />
                <text
                  x={point.x + 12}
                  y={point.y - 8}
                  fill="var(--color-ink)"
                  font-size="13"
                  font-weight="650"
                >
                  {point.place}
                </text>
                <text
                  x={point.x + 12}
                  y={point.y + 9}
                  fill="var(--color-muted)"
                  font-size="12"
                >
                  {point.count}
                </text>
              </g>
            ))
          }
        </svg>
      </div>
    )
  }
</section>
