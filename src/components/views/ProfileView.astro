---
import { render } from "astro:content";
import Avatar from "../Avatar.astro";
import Lightbox from "../Lightbox.astro";
import {
  getPeople,
  getAllPeople,
  getTranslations,
  relationships,
  lifespan,
  initials,
  isLiving,
  type Person,
  type PeopleView,
} from "../../lib/people";
import { useTranslations, localize, type Locale } from "../../i18n/ui";
import { displayTaglineFor } from "../../lib/display";
import PersonMiniCard from "../ui/PersonMiniCard.astro";

interface Props {
  lang: Locale;
  person: Person;
  view?: PeopleView;
}
const { lang, person, view = "core" } = Astro.props;
const t = useTranslations(lang);

const isExtendedProfile = view === "extended";
const people = isExtendedProfile ? await getAllPeople() : await getPeople();
const translations = await getTranslations();
const rels = relationships(person, people);

// English bio comes from the translation entry when present.
const translation = translations.get(person.id);
const bioEntry = lang === "en" && translation ? translation : person;
const { Content } = await render(bioEntry as Person);

const tagline = displayTaglineFor(person, people, translations, lang);
const peoplePath = localize(isExtendedProfile ? "/extended/people" : "/people", lang);

const span = lifespan(person, lang);
const { data } = person;
const living = isLiving(person);

// Age at death — only for deceased with known, non-estimated dates.
const parseDMY = (s?: string) => {
  if (!s || /c\./.test(s)) return null;
  const full = s.match(/(\d{1,2})\.(\d{1,2})\.(\d{4})/);
  if (full) return { d: +full[1], m: +full[2], y: +full[3] };
  const y = s.match(/\d{4}/);
  return y ? { d: 0, m: 0, y: +y[0] } : null;
};
const bornDMY = parseDMY(data.born);
const diedDMY = parseDMY(data.died);
let ageLabel = "";
if (bornDMY && diedDMY) {
  let a = diedDMY.y - bornDMY.y;
  if (
    bornDMY.m &&
    diedDMY.m &&
    (diedDMY.m < bornDMY.m || (diedDMY.m === bornDMY.m && diedDMY.d < bornDMY.d))
  ) {
    a--;
  }
  if (a >= 0 && a < 130) ageLabel = lang === "en" ? `${a} yrs` : `${a} god.`;
}
const spanWithAge = span && ageLabel ? `${span} · ${ageLabel}` : span;

const treeBasePath = localize(isExtendedProfile ? "/extended/tree" : "/tree", lang);
const treeHref = `${treeBasePath}?focus=${person.id}`;
const branchHref = `${treeBasePath}?branch=${person.id}`;
const heroMeta = [
  span && { icon: "📅", value: spanWithAge },
  data.birthplace && { icon: "📍", value: data.birthplace },
].filter(Boolean) as { icon?: string; value: string }[];
const missingFacts = [
  !data.born && t("person.unknownBirth"),
  !data.birthplace && t("person.unknownBirthplace"),
  data.parents.length === 0 && t("person.unknownParents"),
  !person.body?.trim() && t("person.unknownBio"),
].filter(Boolean) as string[];
const miniMapGroups = [
  { label: t("person.parents"), items: rels.parents.map((p) => ({ p })) },
  { label: t("person.spouse"), items: rels.spouses.map((p) => ({ p })) },
  { label: t("person.children"), items: rels.children.slice(0, 8).map((p) => ({ p })) },
  { label: t("person.siblings"), items: rels.siblings.slice(0, 8).map((p) => ({ p })) },
].filter((group) => group.items.length > 0);
---

<article class="mx-auto max-w-6xl px-5 py-10">
  <div class="flex items-center gap-3">
    <a href={peoplePath} class="text-sm text-muted hover:text-accent">
      ← {t("person.back")}
    </a>
  </div>

  <header class="profile-hero mt-6" data-sex={data.sex}>
    <div class="profile-hero-grid">
    <div class="profile-hero-main">
      <Avatar
        name={data.name}
        photo={data.photo}
        initials={initials(data.name)}
        sex={data.sex}
        size="lg"
        lightbox
        class="profile-avatar"
      />
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-3">
          <h1 class="text-4xl font-semibold text-ink">
            {data.name}
          </h1>
          {
            living && (
              <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-medium text-emerald-700 ring-1 ring-emerald-500/20">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-500" />
                {t("person.living")}
              </span>
            )
          }
        </div>
        {data.maidenName && <p class="text-muted">{t("person.nee")} {data.maidenName}</p>}
        {data.nickname && <p class="text-muted">“{data.nickname}”</p>}
        <ul class="profile-meta-list" aria-label={t("person.facts")}>
          {
            heroMeta.map((meta) => (
              <li>
                {
                  meta.icon && (
                    <span class="profile-meta-icon" aria-hidden="true">
                      {meta.icon}
                    </span>
                  )
                }
                <span>{meta.value}</span>
              </li>
            ))
          }
        </ul>
        {tagline && <p class="mt-2 font-medium text-accent">{tagline}</p>}
        {
          missingFacts.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="data-quality-badge">{t("person.needsDetails")}</span>
              {missingFacts.slice(0, 3).map((item) => (
                <span class="data-quality-missing">{item}</span>
              ))}
            </div>
          )
        }
        <div class="profile-hero-actions">
          <a href={treeHref} class="profile-action">{t("person.viewInTree")}</a>
          <a href={branchHref} class="profile-action profile-action--ghost">
            {t("person.openBranch")}
          </a>
        </div>
      </div>
    </div>
    {
      miniMapGroups.length > 0 && (
        <div class="profile-hero-relatives" aria-label={t("person.familyMap")}>
          {miniMapGroups.map((group) => (
            <div class="family-mini-map-group">
              <h3>{group.label}</h3>
              <ul>
                {group.items.map(({ p: rel }) => (
                  <li>
                    <PersonMiniCard person={rel} href={`${peoplePath}/${rel.id}`} />
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )
    }
    </div>
  </header>

  {data.photo && <Lightbox />}

  <section class="profile-bio-section mt-8">
    <h2 class="text-sm font-semibold tracking-wide text-muted uppercase">
      {t("person.bio")}
    </h2>
    <div class="prose mt-4 max-w-none text-ink">
      <Content />
    </div>
  </section>
</article>
