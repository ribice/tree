---
interface Props {
  name: string;
  photo?: string;
  initials: string;
  sex?: "m" | "f";
  size?: "xs" | "sm" | "lg";
  lightbox?: boolean;
  class?: string;
}

const {
  name,
  photo,
  initials,
  sex,
  size = "sm",
  lightbox = false,
  class: klass = "",
} = Astro.props;
const sizes = {
  xs: "h-7 w-7 text-xs",
  sm: "h-12 w-12 text-base",
  lg: "h-40 w-40 text-4xl",
};
const pixels = {
  xs: 28,
  sm: 48,
  lg: 160,
};
const dims = sizes[size];
const px = pixels[size];
const zoomable = lightbox && Boolean(photo);
---

<span
  data-sex={sex}
  class={`avatar flex shrink-0 items-center justify-center overflow-hidden rounded-full bg-accent-soft font-semibold text-accent ring-1 ring-accent/15 ${dims} ${klass}`}
>
  {
    photo ? (
      <img
        src={photo}
        alt={name}
        width={px}
        height={px}
        loading={size === "lg" ? "eager" : "lazy"}
        decoding="async"
        class={`h-full w-full object-cover${zoomable ? " cursor-zoom-in" : ""}`}
        data-lightbox-src={zoomable ? photo : undefined}
        data-lightbox-alt={zoomable ? name : undefined}
      />
    ) : (
      initials
    )
  }
</span>
