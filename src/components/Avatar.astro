---
interface Props {
  name: string;
  photo?: string;
  initials: string;
  size?: "xs" | "sm" | "lg";
  class?: string;
}

const { name, photo, initials, size = "sm", class: klass = "" } = Astro.props;
const sizes = {
  xs: "h-7 w-7 text-xs",
  sm: "h-12 w-12 text-base",
  lg: "h-28 w-28 text-2xl",
};
const pixels = {
  xs: 28,
  sm: 48,
  lg: 112,
};
const dims = sizes[size];
const px = pixels[size];
---

<span
  class={`flex shrink-0 items-center justify-center overflow-hidden rounded-full bg-accent-soft font-semibold text-accent ring-1 ring-accent/15 ${dims} ${klass}`}
>
  {
    photo ? (
      <img
        src={photo}
        alt={name}
        width={px}
        height={px}
        loading={size === "lg" ? "eager" : "lazy"}
        decoding="async"
        class="h-full w-full object-cover"
      />
    ) : (
      initials
    )
  }
</span>
