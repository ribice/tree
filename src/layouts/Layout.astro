---
import "../styles/global.css";
import {
  useTranslations,
  localize,
  type Locale,
} from "../i18n/ui";
import {
  absoluteUrl,
  alternateLinks,
  canonicalUrl,
  jsonLdScript,
  pathForLocale,
  websiteJsonLd,
} from "../lib/seo";

interface Props {
  lang?: Locale;
  title?: string;
  description?: string;
  ogImagePath?: string;
  ogType?: string;
  jsonLd?: unknown | unknown[];
  noindex?: boolean;
}

const {
  lang = "bs",
  title,
  description,
  ogImagePath,
  ogType = "website",
  jsonLd,
  noindex = false,
} = Astro.props;
const t = useTranslations(lang);

const pageTitle = title ?? t("site.title");
const pageDesc = description ?? t("site.description");

const bsPath = pathForLocale(Astro.url.pathname, "bs");
const enPath = pathForLocale(Astro.url.pathname, "en");
const altPath = lang === "bs" ? enPath : bsPath;

const canonical = canonicalUrl(Astro.url.pathname, lang);
const ogImage = absoluteUrl(ogImagePath ?? "/og.png", lang);
const ogLocale = lang === "bs" ? "bs_BA" : "en_US";
const alternates = alternateLinks(Astro.url.pathname);

const nav = [
  { href: localize("/", lang), label: t("nav.home") },
  { href: localize("/tree", lang), label: t("nav.tree") },
  { href: localize("/people", lang), label: t("nav.directory") },
  { href: localize("/about", lang), label: t("nav.about") },
];
const currentPath = pathForLocale(Astro.url.pathname, lang);
const isCurrent = (href: string) =>
  href === localize("/", lang)
    ? currentPath === href
    : currentPath === href || currentPath.startsWith(`${href}/`);
const jsonLdItems = [
  websiteJsonLd({
    locale: lang,
    title: t("site.title"),
    description: t("site.description"),
    url: canonical,
  }),
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDesc} />
    <meta name="theme-color" content="#f7f9fb" />
    <meta name="color-scheme" content="light" />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    {
      alternates.map((a) => (
        <link rel="alternate" hreflang={a.hreflang} href={a.href} />
      ))
    }

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={t("site.title")} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={pageTitle} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />

    <title>{pageTitle}</title>
    {
      jsonLdItems.map((item) => (
        <script type="application/ld+json" set:html={jsonLdScript(item)} />
      ))
    }
    <script is:inline>
      // Keep each domain on its language: stablo.* → Bosnian, tree.* → English.
      (function () {
        try {
          var h = location.hostname,
            p = location.pathname,
            isEn = p === "/en" || p.indexOf("/en/") === 0;
          if (h.indexOf("tree.") === 0 && !isEn)
            location.replace("/en" + (p === "/" ? "/" : p) + location.hash);
          else if (h.indexOf("stablo.") === 0 && isEn)
            location.replace((p.replace(/^\/en/, "") || "/") + location.hash);
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <a class="skip-link" href="#content">{t("nav.skip")}</a>
    <header class="site-header">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3">
        <a
          href={localize("/", lang)}
          class="brand-link"
        >
          <span
            class="flex h-8 w-8 items-center justify-center rounded-lg bg-accent text-surface shadow-sm"
            >❦</span
          >
          <span>{t("site.short")}</span>
        </a>

        <nav class="hidden items-center gap-1 text-sm sm:flex">
          {
            nav.map((item) => (
              <a
                href={item.href}
                aria-current={isCurrent(item.href) ? "page" : undefined}
                class:list={[
                  "nav-link",
                  isCurrent(item.href) && "nav-link-active",
                ]}
              >
                {item.label}
              </a>
            ))
          }
          <a
            href={localize("/add", lang)}
            class="ml-1 rounded-lg bg-accent px-3 py-1.5 font-medium text-surface shadow-sm transition hover:opacity-90"
            >{t("nav.add")}</a
          >
          <a
            href={altPath}
            data-bs={bsPath}
            data-en={enPath}
            class="lang-switch ml-1 rounded-lg border border-line bg-surface/70 px-3 py-1.5 text-muted transition hover:border-accent hover:text-accent"
            >{t("nav.langName")}</a
          >
        </nav>

        <button
          id="menu-btn"
          type="button"
          aria-label="Menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="flex h-9 w-9 items-center justify-center rounded-lg border border-line bg-surface text-ink shadow-sm sm:hidden"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>

      <nav
        id="mobile-menu"
        class="hidden flex-col gap-1 border-t border-line px-5 py-3 text-sm sm:hidden"
      >
        {
          nav.map((item) => (
            <a
              href={item.href}
              aria-current={isCurrent(item.href) ? "page" : undefined}
              class:list={[
                "rounded-lg px-3 py-2 text-muted transition hover:bg-accent-soft hover:text-accent",
                isCurrent(item.href) && "bg-accent-soft text-accent",
              ]}
            >
              {item.label}
            </a>
          ))
        }
        <a
          href={localize("/add", lang)}
          class="mt-1 rounded-lg bg-accent px-3 py-2 text-center font-medium text-surface transition hover:opacity-90"
          >{t("nav.add")}</a
        >
        <a
          href={altPath}
          data-bs={bsPath}
          data-en={enPath}
          class="lang-switch mt-1 rounded-lg border border-line bg-surface px-3 py-2 text-center text-muted transition hover:border-accent hover:text-accent"
          >{t("nav.langName")}</a
        >
      </nav>
    </header>

    <main id="content" class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-line bg-surface/65">
      <div
        class="mx-auto flex max-w-6xl flex-col gap-4 px-5 py-6 text-sm text-muted"
      >
        <nav class="flex flex-wrap gap-x-5 gap-y-2">
          <a href={localize("/stats", lang)} class="transition hover:text-accent"
            >{t("stats.title")}</a
          >
          <a href={localize("/about", lang)} class="transition hover:text-accent"
            >{t("nav.about")}</a
          >
        </nav>
        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
          <p>{t("footer.tagline")}</p>
          <p>
            <a
              href="https://github.com/ribice/tree"
              class="font-medium text-accent hover:underline">{t("footer.github")}</a
            >
          </p>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Mobile menu toggle.
      (function () {
        var btn = document.getElementById("menu-btn");
        var menu = document.getElementById("mobile-menu");
        if (btn && menu)
          btn.addEventListener("click", function () {
            var open = menu.classList.toggle("hidden") === false;
            menu.classList.toggle("flex", open);
            btn.setAttribute("aria-expanded", String(open));
          });
      })();

      // Single-language domains: the switcher hops domains (path-based on localhost).
      (function () {
        var h = location.hostname;
        var to =
          h === "stablo.ribic.ba"
            ? "https://tree.ribic.ba"
            : h === "tree.ribic.ba"
              ? "https://stablo.ribic.ba"
              : null;
        if (!to) return;
        var attr = h === "stablo.ribic.ba" ? "data-en" : "data-bs";
        document.querySelectorAll(".lang-switch").forEach(function (el) {
          el.href = to + el.getAttribute(attr);
        });
      })();
    </script>
  </body>
</html>
