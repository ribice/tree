---
import Layout from "../../../layouts/Layout.astro";
import ProfileView from "../../../components/views/ProfileView.astro";
import { getPeople, getTranslations, taglineFor } from "../../../lib/people";
import { useTranslations } from "../../../i18n/ui";

export async function getStaticPaths() {
  const people = await getPeople();
  return people.map((person) => ({ params: { id: person.id }, props: { person } }));
}

const { person } = Astro.props;
const t = useTranslations("en");
const translations = await getTranslations();
---

<Layout
  lang="en"
  title={`${person.data.name} · ${t("site.title")}`}
  description={taglineFor(person, translations, "en")}
>
  <ProfileView lang="en" person={person} />
</Layout>
