---
import Layout from "../../../layouts/Layout.astro";
import TreeView from "../../../components/views/TreeView.astro";
import { useTranslations } from "../../../i18n/ui";
const t = useTranslations("en");
---

<Layout
  lang="en"
  title={`${t("tree.title")} · ${t("view.extended")} · ${t("site.title")}`}
  description={t("meta.tree")}
>
  <TreeView lang="en" view="extended" />
</Layout>
