---
import Layout from "../layouts/Layout.astro";
---

<Layout lang="bs" title="404 · Ribić – Kifić">
  <section class="mx-auto flex max-w-xl flex-col items-center px-5 py-24 text-center">
    <span
      class="flex h-14 w-14 items-center justify-center rounded-2xl bg-accent-soft text-2xl text-accent"
      >❦</span
    >
    <h1 class="mt-6 text-4xl font-semibold tracking-tight text-ink">404</h1>
    <p class="mt-3 text-muted">
      Ova stranica ne postoji. · This page doesn't exist.
    </p>
    <div class="mt-7 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="rounded-xl bg-accent px-5 py-2.5 font-medium text-surface shadow-sm transition hover:opacity-90"
      >
        Naslovna
      </a>
      <a
        href="/en/"
        class="rounded-xl border border-line bg-surface px-5 py-2.5 font-medium text-ink shadow-sm transition hover:border-accent hover:text-accent"
      >
        Home (English)
      </a>
    </div>
  </section>
</Layout>
