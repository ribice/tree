---
import Layout from "../../layouts/Layout.astro";
import ProfileView from "../../components/views/ProfileView.astro";
import { getPeople } from "../../lib/people";
import { useTranslations } from "../../i18n/ui";

export async function getStaticPaths() {
  const people = await getPeople();
  return people.map((person) => ({ params: { id: person.id }, props: { person } }));
}

const { person } = Astro.props;
const t = useTranslations("bs");
---

<Layout
  lang="bs"
  title={`${person.data.name} · ${t("site.title")}`}
  description={person.data.tagline}
  ogImagePath={`/og/${person.id}.png`}
>
  <ProfileView lang="bs" person={person} />
</Layout>
